  },
  "homepage": "https://github.com/zhwatts/sharelist#readme",
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
