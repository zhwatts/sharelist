# ─── GitHub ──────────────────────────────────────────────────────────────────
# Used by automation scripts (project board, issue management).
# Create a personal access token at https://github.com/settings/tokens
# Required scopes: repo, project
GITHUB_TOKEN=
GITHUB_OWNER=zhwatts
GITHUB_REPO=sharelist
# Numeric project ID — find it in the project URL on GitHub
GITHUB_PROJECT_ID=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com — values are in Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key has full DB access — never expose this to the frontend
SUPABASE_SERVICE_ROLE_KEY=

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001
API_URL=http://localhost:3001
# Origin the API allows CORS requests from (set to your frontend URL in production)
CLIENT_ORIGIN=http://localhost:5173

# ─── Streaming service OAuth ──────────────────────────────────────────────────
# Random 32-byte secret used to HMAC-sign OAuth state parameters (CSRF protection).
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# Spotify — create an app at https://developer.spotify.com/dashboard
# Add the redirect URI in the Spotify app settings under "Redirect URIs".
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3001/streaming/spotify/callback

# Apple Music — requires an Apple Developer account: https://developer.apple.com
# Create a MusicKit identifier and a private key (.p8) in Certificates, Identifiers & Profiles.
# Paste the full contents of the .p8 file as a single line with \n for newlines.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# ─── YouTube Music / Google OAuth ─────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Only needed when working on YouTube Music integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# VITE_ prefix makes these available in the browser bundle.
# The frontend talks exclusively to the Express API — it has no direct Supabase
# access. Do not add VITE_SUPABASE_* vars here.
VITE_API_URL=http://localhost:3001
